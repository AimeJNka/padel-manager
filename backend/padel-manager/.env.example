# ============================================================================
# PadelManager — environment template
# Copy this file to ".env" and replace every placeholder.
# This file is consumed by BOTH:
#   - docker-compose.yml (Postgres container init at the repo root)
#   - Spring Boot application (via spring-dotenv at startup)
# ============================================================================

# Two database users:
#   POSTGRES_USER / FLYWAY_USER = superuser (container init + Flyway DDL migrations)
#   DB_USERNAME                 = least-privilege runtime user (DML only, created by V2)

# ---- Postgres superuser (consumed by docker-compose.yml) -------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=padel_manager

# ---- Spring runtime datasource — least-privilege (consumed by application.yml)
# app_user is created by the V2 migration; its password is fixed there ('padel_password').
DB_USERNAME=app_user
DB_PASSWORD=padel_password

# ---- Flyway DDL user — the Postgres superuser (same creds as POSTGRES_USER/PASSWORD)
FLYWAY_USER=postgres
FLYWAY_PASSWORD=your_password_here

# ---- JWT secret (HS256 — MUST be at least 32 characters) -------------------
# Generate a strong random secret, e.g.:
#   openssl rand -base64 48
JWT_SECRET=your_base64_secret_here_min_256_bits

# ---- Token lifetimes (in milliseconds) -------------------------------------
JWT_EXPIRATION=900000               # member access token: 15 min
JWT_REFRESH_EXPIRATION=604800000    # refresh token: 7 days
# JWT_ADMIN_EXPIRATION=7200000      # admin access token: 2 hours (optional, default in application.yml)
